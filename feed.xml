    <entry>
        <title>South Devon Cycle Touring Trip 2018: Totnes</title>
        <author>
            <name>Mark Carnaby</name>
        </author>
        <link href="https://CarnabySnaps.github.io/travel-photography-cycle-touring-uk/south-devon-cycle-touring-trip-2018-totnes/"/>
        <id>https://CarnabySnaps.github.io/travel-photography-cycle-touring-uk/south-devon-cycle-touring-trip-2018-totnes/</id>
